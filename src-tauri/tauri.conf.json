{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "MXterm",
  "version": "0.1.2",
  "identifier": "com.mxterm.app",
  "build": {
    "beforeDevCommand": "pnpm dev",
    "devUrl": "http://localhost:5420",
    "beforeBuildCommand": "pnpm build && pnpm build:mcp-sidecar",
    "frontendDist": "../dist"
  },
  "app": {
    "macOSPrivateApi": true,
    "windows": [
      {
        "title": "MXterm",
        "width": 1440,
        "height": 900,
        "minWidth": 1100,
        "minHeight": 720,
        "visible": true,
        "decorations": false,
        "transparent": true,
        "dragDropEnabled": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  },
  "plugins": {
    "updater": {
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IDgyQURDMDQ0MzQxRDNGRjEKUldUeFB4MDBSTUN0Z2c5QStnVHBKR25PT2JZTjNQWmZtL2lkdWRSRm1LdDVRSS90SXNFQVBTVEwK",
      "endpoints": [
        "https://github.com/syscryer/mxterm/releases/latest/download/latest.json"
      ],
      "windows": {
        "installMode": "passive"
      }
    }
  }
}
