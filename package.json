{
  "name": "m-xterm",
  "private": true,
  "version": "0.1.2",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc && vite build",
    "build:mcp-sidecar": "cargo build --manifest-path src-tauri/Cargo.toml --release --bin mxterm-mcp",
    "check": "tsc --noEmit",
    "package:win": "node scripts/build-platform.mjs win-x64",
    "package:mac-arm64": "node scripts/build-platform.mjs mac-arm64",
    "package:linux": "node scripts/build-platform.mjs linux-x64",
    "package:all": "node scripts/build-platform.mjs all",
    "test": "node -e \"console.log('frontend tests not configured yet')\"",
    "test:release": "node --test scripts/build-platform.test.mjs scripts/release-assets.test.mjs scripts/generate-latest-json.test.mjs",
    "preview": "vite preview",
    "tauri": "tauri",
    "tauri:dev": "tauri dev"
  },
  "dependencies": {
    "@novnc/novnc": "^1.7.0",
    "@radix-ui/react-context-menu": "^2.2.16",
    "@radix-ui/react-dialog": "^1.1.15",
    "@radix-ui/react-dismissable-layer": "^1.1.11",
    "@radix-ui/react-tooltip": "^1.2.8",
    "@tauri-apps/api": "^2",
    "@tauri-apps/plugin-dialog": "^2.7.1",
    "@tauri-apps/plugin-opener": "^2",
    "@tauri-apps/plugin-process": "^2.3.1",
    "@tauri-apps/plugin-updater": "^2.10.1",
    "@xterm/addon-fit": "^0.11.0",
    "@xterm/addon-search": "^0.16.0",
    "@xterm/addon-unicode11": "^0.9.0",
    "@xterm/addon-web-links": "^0.12.0",
    "@xterm/xterm": "^6.0.0",
    "lucide-react": "^1.17.0",
    "monaco-editor": "^0.55.1",
    "react": "^19.1.0",
    "react-dom": "^19.1.0",
    "simple-icons": "^16.23.0"
  },
  "devDependencies": {
    "@tauri-apps/cli": "^2",
    "@types/react": "^19.1.8",
    "@types/react-dom": "^19.1.6",
    "@vitejs/plugin-react": "^4.6.0",
    "typescript": "~5.8.3",
    "vite": "^7.0.4"
  }
}
